# Day 22 lab — env template. Copy to .env and fill in.
# Both tiers default to T4 (free Colab); flip COMPUTE_TIER to BIGGPU on A100/L4.

# ───────────────────────────────────────────────────────────
# Compute tier — picks model size, batch, dataset slice
# ───────────────────────────────────────────────────────────
COMPUTE_TIER=T4                     # T4 | BIGGPU

# T4    → Llama-3.2-1B-Instruct-bnb-4bit, 2k pref pairs, max_length=512, batch=1 grad_accum=8
# BIGGPU → same fast Llama-3.2-1B base, larger sequence/batch only

# ───────────────────────────────────────────────────────────
# Model + dataset overrides (optional — defaults set by COMPUTE_TIER)
# ───────────────────────────────────────────────────────────
# BASE_MODEL=unsloth/Llama-3.2-1B-Instruct-bnb-4bit
# SFT_DATASET=bkai-foundation-models/vi-alpaca
# PREF_DATASET=argilla/ultrafeedback-binarized-preferences-cleaned
# PREF_SLICE=2000
# SFT_SLICE=1000

# ───────────────────────────────────────────────────────────
# DPO hyperparameters (defaults match deck §5.2)
# ───────────────────────────────────────────────────────────
DPO_BETA=0.1
DPO_LR=5e-7
DPO_EPOCHS=1

# ───────────────────────────────────────────────────────────
# Optional: API judges for notebook 04 (only if you have keys)
# Without keys, notebook 04 falls back to manual rubric mode.
# ───────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# JUDGE_MODEL=gpt-4o-mini             # gpt-4o-mini | claude-haiku-4-5

# ───────────────────────────────────────────────────────────
# Optional: HuggingFace push (Submission Option B = +5 bonus)
# ───────────────────────────────────────────────────────────
# HF_TOKEN=hf_...
# HF_REPO=<your-username>/lab22-dpo-vn

# ───────────────────────────────────────────────────────────
# Optional: Weights & Biases (one of the +20 bonus rigor add-ons)
# ───────────────────────────────────────────────────────────
# WANDB_API_KEY=...
# WANDB_PROJECT=lab22-dpo

# ───────────────────────────────────────────────────────────
# Optional: faster/lighter Colab reruns
# ───────────────────────────────────────────────────────────
# LAB_MINIMAL=1
# LIMIT_IFEVAL=64
# LIMIT_GSM8K=40
# LIMIT_MMLU=40
# LIMIT_ALPACA=16
# EVAL_MAX_NEW_TOKENS=160

# Stability toggles for Colab runtimes.
# FORCE_SDPA_ATTENTION=1
# FORCE_FP16=1
# INSTALL_BIGGPU_EXTRAS=1              # optional vLLM/flash-attn only
